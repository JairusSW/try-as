{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "removeComments": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./lib",
    "sourceMap": false,
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["./src/*.ts", "src/linkers/*.ts", "src/passes/linker.ts"]
}
